# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Output Color Modes ─────────────────────────────
# Comma-separated: RGB,CMYK (both enabled by default)
# To disable CMYK: OUTPUT_COLOR_MODES=RGB
# To disable RGB:  OUTPUT_COLOR_MODES=CMYK
OUTPUT_COLOR_MODES=RGB,CMYK

# ── Shopify ─────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=backmybracket.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_HOODIE_PRODUCT_URL=https://backmybracket.com/products/bmb-grid-iron-hoodie

# ── Email (Printer) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=orders@backmybracket.com
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
PRINTER_EMAIL=jkim@aceusainc.com
CC_EMAILS=ahmad@backmybracket.com,amchi81@gmail.com

# ── Email Retry ─────────────────────────────────────
# Max retries on email send failure (default 3)
EMAIL_MAX_RETRIES=3
# Base delay in ms between retries (doubles each time: 2s, 4s, 8s)
EMAIL_RETRY_BASE_MS=2000

# ── Admin ───────────────────────────────────────────
# Secret token for admin endpoints (PATCH /admin/products, GET /admin/fulfillment)
# Generate a strong random token for production use
ADMIN_TOKEN=bmb-admin-secret-change-me

# ── Printer Delivery ───────────────────────────────
# Comma-separated: email|folder|sftp
# email  — SMTP email to printer (primary, default)
# folder — Copy files to local printer_dropbox/ directory
# sftp   — Upload files to remote SFTP server
PRINTER_DELIVERY=email

# ── Printer Dropbox (for folder delivery) ──────────
# Default: ./printer_dropbox
# PRINTER_DROPBOX_DIR=/path/to/shared/folder

# ── SFTP (for sftp delivery) ───────────────────────
# SFTP_HOST=sftp.printshop.example.com
# SFTP_PORT=22
# SFTP_USER=bmb_upload
# SFTP_PASS=xxxxxxxxxxxxxxxxxxxx
# SFTP_REMOTE_DIR=/incoming/bmb

# ── Storage (optional — defaults to local disk) ────
# S3_BUCKET=bmb-print-files
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
